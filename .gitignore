# CodeRenga .gitignore
# Ignore generated binaries, local caches, local agent settings, icon assets,
# runtime state, backups, and secrets.

# ---------------------------------------------------------------------
# Local agent/editor instruction files
# ---------------------------------------------------------------------
AGENTS.md
.agents/
.codex/

# ---------------------------------------------------------------------
# Local scratch / backups / downloaded toolchains
# ---------------------------------------------------------------------
.local/
backup/
.backup/
*.bak
*.orig
*.rej
*.tmp
*.temp

# ---------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------
bin/
dist/
build/
out/
release/
releases/
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.obj
*.pdb
*.ilk
*.test
*.prof
*.cover
coverage.out

# ---------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------
go.work
go.work.sum
vendor/

# Go build/test cache if redirected into the repo
cache/
go-build/

# ---------------------------------------------------------------------
# Icons / Windows resources
# ---------------------------------------------------------------------
assets/icon*
assets/*icon*
assets/*.ico
assets/*.png
assets/*.icns
*.ico
*.icns
*.syso
*.rc

# Official CodeRenga application assets and generated Windows resource
!assets/
!assets/CodeRenga.ico
!assets/CodeRenga.png
!cmd/coderenga/rsrc_windows_amd64.syso

# ---------------------------------------------------------------------
# CodeRenga runtime/config/state generated by --init or local execution
# ---------------------------------------------------------------------
/coderenga.d/
.coderenga/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------
# Dry-run / patches / temporary runtime outputs
# ---------------------------------------------------------------------
dry-run/
patches/
tmp/
temp/

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.crt
*.p12
*.pfx

# ---------------------------------------------------------------------
# Editor / OS files
# ---------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------
# Node/frontend tooling, if added later
# ---------------------------------------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.next/
.nuxt/
coverage/

# ---------------------------------------------------------------------
# Python helper environments, if scripts are used
# ---------------------------------------------------------------------
.venv/
venv/
__pycache__/
*.pyc

# ---------------------------------------------------------------------
# Archives and downloaded packages
# ---------------------------------------------------------------------
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.xz
*.zst

# ---------------------------------------------------------------------
# Generated documents / local exports
# ---------------------------------------------------------------------
*.docx
*.pdf

# ---------------------------------------------------------------------
# Local structure dumps
# ---------------------------------------------------------------------
structure.txt
files.txt
status.txt
